# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Public base URL of the site (used for absolute links, Stripe redirects).
BASE_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically in production.
# For local dev, point at your local Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/glasscity
# Set to "true" for Railway managed Postgres (requires SSL). Leave unset locally.
DB_SSL=false

# ── Auth (Phase 2) ───────────────────────────────────────────────────
# Secret used to sign operator JWTs. REQUIRED in production (the app refuses
# to boot without it). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string
# Token lifetimes (any value `jsonwebtoken` accepts) and bcrypt cost. Optional.
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL=30d
# BCRYPT_ROUNDS=12

# ── Stripe (Phase 5) ─────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Email — Resend (Phase 5) ─────────────────────────────────────────
# RESEND_API_KEY=
# FROM address for outbound transactional email (confirmations/receipts).
# FROM_EMAIL=hello@blackswamptotes.com
# Public contact/support address shown on the site (footer + legal pages).
# Defaults to support@blackswamptotes.com. This is the address customers
# write to — keep it distinct from FROM_EMAIL (outbound) and OWNER_EMAIL.
# SUPPORT_EMAIL=support@blackswamptotes.com

# ── SMS — Twilio (Phase 8 / Session 3) ───────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX        # the Twilio number you buy
# OPERATOR_PHONE=+14195XXXXXX             # owner cell — texted on new bookings

# ── Web Push — VAPID (Phase 8 / Session 3) ───────────────────────────
# Generate: node -e "console.log(require('web-push').generateVAPIDKeys())"
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=eb333659@gmail.com          # or VAPID_SUBJECT=mailto:...

# ── Monitoring — Sentry (Phase 9) ────────────────────────────────────
# SENTRY_DSN=

# ── SEO ──────────────────────────────────────────────────────────────
# Canonical public origin for sitemap.xml / robots.txt. Defaults to BASE_URL,
# then the request host. Set once the custom domain is live.
# SITE_URL=https://glasscitytrailerrentals.com

# ── Marketing analytics (optional) ───────────────────────────────────
# GA4 Measurement ID — Google Analytics → Admin → Data Streams → your web
# stream → "Measurement ID" (format G-XXXXXXXXXX). Unset = no GA script.
# GOOGLE_ANALYTICS_ID=
# Meta/Facebook Pixel ID — Meta Events Manager → Data Sources → your pixel →
# the numeric Pixel ID. Unset = no Pixel script.
# FACEBOOK_PIXEL_ID=

# ── Reviews ──────────────────────────────────────────────────────────
# Direct "write a review" link, sent ~4h after a return. Get the Place ID from
# the Google Business Profile / Place ID Finder, then use:
#   https://search.google.com/local/writereview?placeid=YOUR_PLACE_ID
# Unset = review requests are skipped.
# GOOGLE_REVIEW_LINK=

# Owner email — internal recipient for monthly statements/reports (not shown
# publicly; the public contact address is SUPPORT_EMAIL above).
# OWNER_EMAIL=

# ── Cron — automated reminders ───────────────────────────────────────
# Shared secret for the hourly reminder endpoint (GET|POST /api/cron/reminders).
# Point an external scheduler (e.g. cron-job.org) at that URL with header
# "Authorization: Bearer <CRON_SECRET>". Unset = the endpoint returns 503.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# CRON_SECRET=
