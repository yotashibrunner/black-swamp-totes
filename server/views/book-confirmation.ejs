<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Booking <%= booking.ref_code %> | Black Swamp Totes</title>
  <link rel="icon" href="/images/logo.png?v=2" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/site.css" />
  <%- typeof analyticsHead !== 'undefined' ? analyticsHead : '' %>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-head">
    <div class="site-head-inner">
      <a class="back" href="/">‹ <span>Home</span></a>
      <a href="/" aria-label="Black Swamp Totes home"><%- include("partials/cattail") %></a>
      <a class="call" href="tel:+14192622837" aria-label="Call Black Swamp Totes">Call</a>
    </div>
  </header>

  <main class="container" id="main">
    <div style="max-width:560px;margin:44px auto 80px;">
      <%
        var paid = booking.status === 'paid' || justPaid;
        var signed = !!booking.contract_signed_at;
        var statusLabel = paid ? 'Confirmed & Paid' : (signed ? 'Signed — Payment Pending' : 'Pending');
      %>
      <div class="eyebrow"><%= paid ? 'Booking Confirmed' : 'Booking' %></div>
      <h1 class="display" style="font-size:clamp(40px,8vw,72px);margin:8px 0;"><%= booking.ref_code %></h1>
      <% if (paid) { %>
      <p class="qnote" style="color:var(--green);font-weight:700;margin:0 0 4px;font-size:15px;">✓ Booking confirmed — you're all set. Save your reference code above.</p>
      <% } %>

      <div class="panel" style="position:static;">
        <div class="quote" style="border-top:0;padding-top:0;">
          <div class="qrow"><span>Status</span><span style="color:<%= paid ? 'var(--green)' : 'var(--hazard)' %>"><%= statusLabel %></span></div>
          <div class="qrow"><span>Package</span><span><%= booking.trailer_name %></span></div>
          <% if (booking.bin_count) { %>
          <div class="qrow"><span>Bins</span><span><%= booking.bin_count %> bins<%= booking.dolly_count ? ' · ' + booking.dolly_count + ' doll' + (booking.dolly_count === 1 ? 'y' : 'ies') : '' %></span></div>
          <% } %>
          <div class="qrow"><span>Fulfillment</span><span><%= booking.fulfillment === 'delivery' ? 'Delivery' : 'Customer pickup' %></span></div>
          <% if (booking.fulfillment === 'delivery' && booking.delivery_address) { %>
          <div class="qrow"><span>Address</span><span><%= booking.delivery_address %></span></div>
          <% } %>
          <div class="qrow"><span><%= booking.fulfillment === 'delivery' ? 'Delivery' : (booking.trailer_type === 'dumpster' ? 'Drop-off' : 'Pickup') %></span><span><%= new Date(booking.start_at).toLocaleDateString('en-US', { timeZone:'UTC', month:'short', day:'numeric', year:'numeric' }) %></span></div>
          <%
            var sd = new Date(booking.start_at);
            var hasTime = !(sd.getUTCHours() === 0 && sd.getUTCMinutes() === 0);
            var timeLabel = booking.fulfillment === 'delivery' ? 'Delivery time'
              : (booking.trailer_type === 'dumpster' ? 'Drop-off time' : 'Pickup time');
          %>
          <% if (hasTime) { %>
          <div class="qrow"><span><%= timeLabel %></span><span><%= sd.toLocaleTimeString('en-US', { timeZone:'UTC', hour:'numeric', minute:'2-digit' }) %></span></div>
          <% } %>
          <div class="qrow"><span><%= booking.trailer_type === 'dumpster' ? 'Pickup' : 'Return' %></span><span><%= new Date(booking.end_at).toLocaleDateString('en-US', { timeZone:'UTC', month:'short', day:'numeric', year:'numeric' }) %></span></div>
          <% if (booking.student_discount_applied && booking.discount_cents > 0) { %>
          <div class="qrow"><span>Package price</span><span><%= fmt(booking.base_amount_cents) %></span></div>
          <div class="qrow"><span>🎓 Student discount (20%)</span><span style="color:var(--green)">−<%= fmt(booking.discount_cents) %></span></div>
          <% } %>
          <div class="qtotal">
            <span class="lbl"><%= paid ? 'Paid' : 'Total charged' %></span>
            <span class="val"><%= fmt(booking.total_cents) %></span>
          </div>
        </div>

        <% if (booking.fulfillment === 'delivery') { %>
        <p class="qnote" style="margin-top:16px;">
          We’ll deliver to <strong><%= booking.delivery_address %></strong> and pick it back up. We’ll be in touch to confirm your delivery time.
        </p>
        <% } else { %>
        <p class="qnote" style="margin-top:16px;">
          We’ll deliver your bins to your door and pick them back up when you’re done — free. We’ll be in touch to confirm your delivery time.
        </p>
        <% } %>

        <% if (booking.bin_count) { var impBoxes = booking.bin_count * 1; var impLbs = Math.round(impBoxes * 2.5); %>
        <p class="qnote" style="margin-top:14px;color:var(--green);font-weight:600;">
          🌿 Your rental keeps <%= impBoxes %> cardboard boxes and <%= impLbs %> lbs of cardboard out of Toledo landfills.
        </p>
        <% } %>

        <% if (signed) { %>
          <a class="btn btn-ghost" href="/api/bookings/<%= booking.ref_code %>/contract.pdf" target="_blank" rel="noopener" style="margin-top:14px;">Download Signed Agreement (PDF)</a>
        <% } %>
        <a class="btn btn-ghost" href="/book/<%= booking.ref_code %>/calendar.ics" style="margin-top:10px;">Add to Calendar (.ics)</a>
        <a class="btn btn-ghost" href="/my-booking?ref=<%= booking.ref_code %>" style="margin-top:10px;">Need to make changes? Manage your booking</a>
        <p class="qnote" style="margin-top:14px;">Questions about your booking? Call <a href="tel:+14192622837">(419) 262-2837</a>.</p>
      </div>

      <% if (justPaid) { %>
        <p class="qnote" style="text-align:center;margin-top:18px;color:var(--green);">Payment received — a confirmation email with your signed agreement is on its way.</p>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>

  <% if (booking.status === 'paid' && typeof facebookPixelId !== 'undefined' && facebookPixelId) { %>
  <script>
    if (window.fbq) fbq('track', 'Purchase', { value: <%= (booking.total_cents / 100).toFixed(2) %>, currency: 'USD' });
  </script>
  <% } %>
</body>
</html>
