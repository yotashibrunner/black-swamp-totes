<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reserve <%= trailer.name %> | Black Swamp Totes</title>
  <link rel="icon" href="/images/logo.png?v=2" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/site.css" />
  <%- typeof analyticsHead !== 'undefined' ? analyticsHead : '' %>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-head">
    <div class="site-head-inner">
      <a class="back" href="<%= isDumpster ? '/book/dumpster' : '/fleet/' + trailer.slug %>">‹ <span>Back</span></a>
      <a href="/" aria-label="Black Swamp Totes home"><%- include("partials/cattail") %></a>
      <a class="call" href="tel:+14192622837" aria-label="Call Black Swamp Totes">Call</a>
    </div>
  </header>

  <main class="container" id="main">
    <div class="detail">
      <section>
        <div class="crumb">Reserve / Step 1 of 3 — Your Info</div>
        <h1 class="display"><%= trailer.name %></h1>

        <div class="eyebrow" style="margin:18px 0 10px;">Order Summary</div>
        <div class="quote" style="border-top:0;padding-top:0;">
          <% if (isBins) { %>
            <div class="qrow"><span>Delivery date</span><span><%= selection.start_at %></span></div>
            <div class="qrow"><span>Pickup date</span><span><%= selection.end_at %></span></div>
            <div class="qrow"><span>Rental term</span><span><%= quote.weeks || quote.quantity %> week<%= (quote.weeks || quote.quantity) > 1 ? 's' : '' %><%= quote.extra_days ? ' + ' + quote.extra_days + ' day' + (quote.extra_days > 1 ? 's' : '') : '' %></span></div>
            <% if (quote.extra_days) { %>
            <div class="qrow"><span class="dim">Extra days <span class="dim">($<%= ((quote.extension_rate_per_bin_cents || 30) / 100).toFixed(2) %>/bin/day)</span></span><span class="dim"><%= quote.extra_days %> × <%= quote.bin_count %> bins</span></div>
            <% } %>
            <div class="qrow"><span>Bins</span><span id="sumBins"><%= quote.bin_count %></span></div>
            <% if (trailer.is_custom) { %>
            <div class="field-row" style="margin:8px 0;">
              <div>
                <label class="fl" for="binQty">How many bins? <span class="dim">(min 10)</span></label>
                <input type="number" id="binQty" min="10" step="1" value="<%= quote.bin_count %>" inputmode="numeric" />
              </div>
            </div>
            <% } %>
          <% } else if (isDumpster) { %>
            <div class="qrow"><span>Drop-off date</span><span><%= selection.start_at %></span></div>
            <div class="qrow"><span>Extra days</span><span><%= selection.extra_days %></span></div>
          <% } else { %>
            <div class="qrow"><span>Pickup</span><span><%= selection.start_at %></span></div>
            <div class="qrow"><span>Return</span><span><%= selection.end_at %></span></div>
            <div class="qrow"><span>Days</span><span><%= quote.quantity %></span></div>
          <% } %>
          <div class="qrow"><span>Subtotal</span><span id="sumSubtotal"><%= fmt(quote.base_cents) %></span></div>
          <div class="qrow"><span>Tax</span><span id="sumTax"><%= fmt(quote.tax_cents) %></span></div>
          <% if (isBins) { %>
            <div class="qrow"><span>Delivery &amp; pickup</span><span style="color:var(--green)">Free</span></div>
          <% } else { %>
            <div class="qrow" id="sumDeliveryRow" hidden><span>Delivery</span><span id="sumDelivery"><%= fmt(deliveryFeeCents) %></span></div>
          <% } %>
          <div class="qrow" id="sumDiscountRow" hidden><span><span id="sumDiscountLabel">Discount</span> <span id="sumCouponCode" class="dim"></span></span><span id="sumDiscount" style="color:var(--green)"></span></div>
          <div class="qrow" id="sumStudentRow" hidden><span>🎓 Student discount (20%)</span><span id="sumStudent" style="color:var(--green)"></span></div>
          <div class="qtotal">
            <span class="lbl">Total</span>
            <span class="val" id="sumTotal"><%= fmt(quote.total_cents) %></span>
          </div>
          <% if (isBins) { %>
          <p class="qnote">Full balance is charged after you sign the rental agreement. We deliver clean bins to your door and pick them up when you're done — <strong>free</strong>. Extensions are $0.30 per bin per day.</p>
          <% } else { %>
          <p class="qnote">Full balance is charged after you sign the rental agreement.</p>
          <% } %>

          <div style="margin-top:14px;">
            <label class="fl" for="couponCode">Have a discount code?</label>
            <div style="display:flex;gap:8px;align-items:stretch;">
              <input type="text" id="couponCode" placeholder="Enter code" autocomplete="off" autocapitalize="characters" style="text-transform:uppercase;flex:1;" />
              <button type="button" class="btn btn-ghost" id="applyCoupon" style="width:auto;white-space:nowrap;">Apply</button>
            </div>
            <p class="qnote" id="couponMsg" role="status" aria-live="polite" style="margin-top:6px;"></p>
          </div>
        </div>
      </section>

      <aside class="panel">
        <h2>Your Information</h2>
        <form id="bookForm" novalidate>
          <div class="step">Contact</div>
          <div class="field-row"><div><label class="fl" for="name">Full name <span class="req" aria-hidden="true">*</span><span class="sr-only">(required)</span></label><input type="text" id="name" autocomplete="name" required aria-required="true" /></div></div>
          <div class="field-row two" style="margin-top:12px;">
            <div><label class="fl" for="phone">Phone <span class="req" aria-hidden="true">*</span><span class="sr-only">(required)</span></label><input type="text" id="phone" inputmode="tel" autocomplete="tel" required aria-required="true" /></div>
            <div><label class="fl" for="email">Email <span class="req" aria-hidden="true">*</span><span class="sr-only">(required)</span></label><input type="email" id="email" inputmode="email" autocomplete="email" required aria-required="true" /></div>
          </div>
          <div id="studentBox" role="status" aria-live="polite" hidden style="margin-top:10px;background:rgba(34,197,94,.1);border:1px solid var(--green);border-radius:10px;padding:12px 14px;font-size:13px;">
            <div style="color:var(--green);font-weight:700;margin-bottom:8px;">🎓 Student discount applied — 20% off your rental</div>
            <div style="display:flex;justify-content:space-between;"><span>Original price</span><span id="sbOriginal"></span></div>
            <div style="display:flex;justify-content:space-between;"><span>Student discount</span><span id="sbDiscount" style="color:var(--green)"></span></div>
            <div style="display:flex;justify-content:space-between;font-weight:700;margin-top:4px;"><span>Your total</span><span id="sbTotal"></span></div>
          </div>

          <div class="step"><label class="fl" for="startTime" id="timeLabel" style="margin:0;"><%= isBins ? 'Preferred Delivery Time' : (isDumpster ? 'Preferred Drop-off Time' : 'Preferred Pickup Time') %></label></div>
          <div class="field-row">
            <div>
              <select id="startTime">
                <option value="07:00">7:00 AM</option>
                <option value="08:00">8:00 AM</option>
                <option value="09:00" selected>9:00 AM</option>
                <option value="10:00">10:00 AM</option>
                <option value="11:00">11:00 AM</option>
                <option value="12:00">12:00 PM</option>
                <option value="13:00">1:00 PM</option>
                <option value="14:00">2:00 PM</option>
                <option value="15:00">3:00 PM</option>
                <option value="16:00">4:00 PM</option>
                <option value="17:00">5:00 PM</option>
                <option value="18:00">6:00 PM</option>
              </select>
              <p class="qnote" style="margin-top:6px;">Business hours 7am–7pm. We'll confirm the exact window.</p>
            </div>
          </div>
<% if (isBins) { %>
          <div class="step">Delivery</div>
          <p class="qnote" style="margin:0 0 10px;">We deliver throughout Toledo, Bowling Green, Maumee, Perrysburg, Sylvania, Oregon, and Northwood. Not on the list? Call (419) 262-2837 — we may be able to help.</p>
          <div class="field-row">
            <div>
              <label class="fl" for="deliveryAddr">Where should we deliver your bins? <span class="req" aria-hidden="true">*</span><span class="sr-only">(required)</span></label>
              <input type="text" id="deliveryAddr" autocomplete="street-address" placeholder="123 Main St, Toledo, OH 43615" required aria-required="true" />
            </div>
          </div>
          <div class="field-row" style="margin-top:12px;">
            <div>
              <label class="fl" for="pickupAddr">Where should we pick up from? <span class="dim">(optional)</span></label>
              <input type="text" id="pickupAddr" autocomplete="off" placeholder="Leave blank if same as delivery" />
              <p class="qnote" style="margin-top:6px;">This can be your new address if you're moving — we'll come to you. You can update it later from <a href="/my-booking">Manage a Booking</a> or by texting us when you're ready for pickup.</p>
            </div>
          </div>
<% } else if (!isDumpster) { %>
          <div class="step">Fulfillment</div>
          <div role="radiogroup" aria-label="Fulfillment" style="display:flex;flex-direction:column;gap:8px;">
            <label class="tire-ack" style="color:var(--ink);"><input type="radio" name="fulfillment" value="pickup" checked /> <span>Customer Pickup — <strong>Free</strong></span></label>
            <label class="tire-ack" style="color:var(--ink);"><input type="radio" name="fulfillment" value="delivery" /> <span>Delivery — <strong><%= fmt(deliveryFeeCents) %></strong></span></label>
          </div>
          <div id="addrRow" hidden style="margin-top:12px;">
            <div class="field-row"><div><label class="fl" for="deliveryAddr">Delivery address <span class="req" aria-hidden="true">*</span></label><input type="text" id="deliveryAddr" autocomplete="street-address" placeholder="123 Main St, Toledo, OH 43614" /></div></div>
          </div>
<% } %>
          <div class="step">Notes</div>
          <div class="field-row"><div><label class="fl" for="notes">Notes (optional)</label><input type="text" id="notes" placeholder="Gate code, contactless drop, anything we should know?" /></div></div>

          <label class="tire-ack" id="termsAck" style="color:var(--ink);align-items:flex-start;margin-top:6px;">
            <input type="checkbox" id="agreeTerms" required aria-required="true" />
            <span>I have read and agree to the <a href="/rental-agreement" target="_blank" rel="noopener"><strong>Rental Agreement and Liability Waiver</strong></a><span class="req" aria-hidden="true"> *</span>.</span>
          </label>

          <button class="btn btn-primary" id="continueBtn" type="submit">Continue to Sign →</button>
          <p class="err" id="err" role="alert" aria-live="assertive"></p>
          <p class="qnote">Next: review &amp; e-sign the rental agreement, then pay the balance securely.</p>
          <p class="qnote">You also agree to our <a href="/terms" target="_blank" rel="noopener">Terms of Service</a> and <a href="/privacy" target="_blank" rel="noopener">Privacy Policy</a>.</p>
        </form>
      </aside>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script id="selection-data" type="application/json"><%- JSON.stringify(selection) %></script>
  <script>
    (function () {
      var sel = JSON.parse(document.getElementById('selection-data').textContent);
      var el = function (id) { return document.getElementById(id); };
      var form = el('bookForm');
      function money(c) { return c % 100 === 0 ? '$' + (c / 100) : '$' + (c / 100).toFixed(2); }

      var IS_BINS = <%= isBins ? 'true' : 'false' %>;
      var IS_DUMPSTER = <%= isDumpster ? 'true' : 'false' %>;
      var IS_CUSTOM = <%= (isBins && trailer.is_custom) ? 'true' : 'false' %>;
      var TRAILER_ID = '<%= trailer.id %>';
      var TERMS_VERSION = '<%= termsVersion %>';
      var DELIVERY_FEE = <%= deliveryFeeCents %>;
      var WEEKS = <%= quote.weeks || quote.quantity || 1 %>;
      var EXTRA_DAYS = <%= quote.extra_days || 0 %>;
      var EXT_RATE = <%= quote.extension_rate_per_bin_cents || 30 %>; // per bin per day
      var PER_BIN_WK = <%= trailer.weekly_rate || 0 %>;   // custom: per bin per week
      var TAX_RATE = <%= quote.tax_rate || 0 %>;
      var FIXED_BASE = <%= quote.base_cents %>;            // non-custom base (incl. extra days)
      var couponCode = null;   // last applied promo/partner code; the server validates + prices it
      var quoteTimer = null;

      function currentFulfillment() {
        if (IS_BINS) return 'delivery';
        var d = document.querySelector('input[name="fulfillment"]:checked');
        return d && d.value === 'delivery' ? 'delivery' : 'pickup';
      }
      function binQty() {
        return IS_CUSTOM ? Math.max(10, parseInt((el('binQty') || {}).value, 10) || 10) : null;
      }

      // Non-money UI that can update instantly (no server round-trip needed).
      function nonMoneyUI() {
        var delivery = !IS_BINS && currentFulfillment() === 'delivery';
        var label = el('timeLabel');
        if (label && !IS_BINS) label.textContent = IS_DUMPSTER ? 'Preferred Drop-off Time' : (delivery ? 'Preferred Delivery Time' : 'Preferred Pickup Time');
        var addrRow = el('addrRow');
        if (addrRow) addrRow.hidden = !delivery;
      }

      function updateStudentBox(q) {
        var box = el('studentBox');
        if (!box) return;
        if (q && q.student_discount_applied) {
          el('sbOriginal').textContent = q.base_fmt;
          el('sbDiscount').textContent = '-' + (q.discount_fmt || money(q.discount_cents || 0));
          el('sbTotal').textContent = q.total_fmt;
          box.hidden = false;
        } else {
          box.hidden = true;
        }
      }

      // Render the order summary ENTIRELY from the server quote (single source of
      // truth: pricing.computeQuote + priceWithDiscounts). A discount row shows
      // ONLY when the server actually applied one, and the total always reflects it.
      function renderQuote(q) {
        if (!q) return;
        if (el('sumSubtotal')) el('sumSubtotal').textContent = q.base_fmt;
        if (el('sumTax')) el('sumTax').textContent = q.tax_fmt;
        if (el('sumBins') && q.bin_count != null) el('sumBins').textContent = q.bin_count;

        var feeRow = el('sumDeliveryRow');
        if (feeRow) {
          var fee = q.delivery_fee_cents || 0;
          feeRow.hidden = fee <= 0;
          if (fee > 0 && el('sumDelivery')) el('sumDelivery').textContent = money(fee);
        }

        var isStudent = !!q.student_discount_applied;
        var disc = q.discount_cents || 0;
        var discRow = el('sumDiscountRow');
        if (discRow) {
          var showCoupon = !isStudent && disc > 0;
          discRow.hidden = !showCoupon;
          if (showCoupon) {
            if (el('sumDiscountLabel')) el('sumDiscountLabel').textContent = (q.coupon && q.coupon.line_label) || 'Discount';
            if (el('sumCouponCode')) el('sumCouponCode').textContent = (q.coupon && q.coupon.code) ? '(' + q.coupon.code + ')' : '';
            el('sumDiscount').textContent = '−' + money(disc);
          }
        }
        var stuRow = el('sumStudentRow');
        if (stuRow) { stuRow.hidden = !isStudent; if (isStudent) el('sumStudent').textContent = '−' + money(disc); }

        if (el('sumTotal')) el('sumTotal').textContent = q.total_fmt;
        updateStudentBox(q);

        // Coupon feedback message (only after a code has been entered).
        var msg = el('couponMsg');
        if (msg && couponCode) {
          if (q.coupon && q.coupon.valid === false) { msg.style.color = 'var(--hazard)'; msg.textContent = q.coupon.message || 'That code isn’t valid.'; }
          else if (q.coupon && q.coupon.valid) { msg.style.color = 'var(--green)'; msg.textContent = q.coupon.message || 'Discount applied.'; }
        } else if (msg && !couponCode) { msg.textContent = ''; }
      }

      function quoteBody() {
        return {
          slug: sel.slug,
          period_type: sel.period_type,
          start_at: sel.start_at, end_at: sel.end_at,
          extra_days: sel.extra_days, quantity: sel.extra_days,
          bin_quantity: binQty(),
          fulfillment: currentFulfillment(),
          customer_email: (el('email') && el('email').value || '').trim(),
          coupon_code: couponCode || undefined,
        };
      }

      async function refreshQuote() {
        nonMoneyUI();
        try {
          var res = await fetch('/api/quote', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(quoteBody()),
          });
          var data = await res.json().catch(function () { return null; });
          if (res.ok) renderQuote(data);
        } catch (e) { /* keep the last good numbers on a transient error */ }
      }
      function scheduleRefresh() { clearTimeout(quoteTimer); quoteTimer = setTimeout(refreshQuote, 250); }

      if (el('email')) el('email').addEventListener('input', scheduleRefresh);
      if (el('binQty')) el('binQty').addEventListener('input', scheduleRefresh);
      Array.prototype.forEach.call(document.querySelectorAll('input[name="fulfillment"]'), function (r) {
        r.addEventListener('change', refreshQuote);
      });
      refreshQuote();

      // Discount code: hand the code to the server, which validates + prices it.
      // The quote response carries validity, the label, and the new total.
      el('applyCoupon').addEventListener('click', function () {
        couponCode = el('couponCode').value.trim().toUpperCase() || null;
        if (!couponCode && el('sumCouponCode')) el('sumCouponCode').textContent = '';
        refreshQuote();
      });

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        el('err').textContent = '';
        var name = el('name').value.trim();
        var phone = el('phone').value.trim();
        var email = el('email').value.trim();
        if (!name || !phone) { el('err').textContent = 'Name and phone are required.'; return; }
        if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) { el('err').textContent = 'A valid email is required — we send your confirmation and receipt there.'; return; }
        if (!el('agreeTerms').checked) {
          el('err').textContent = 'Please read and agree to the Rental Agreement and Liability Waiver to continue.';
          el('agreeTerms').focus();
          return;
        }

        var body = Object.assign({}, sel, {
          customer: { name: name, phone: phone, email: email },
          notes: el('notes').value.trim(),
          start_time: el('startTime').value || null,
          coupon_code: couponCode || undefined,
          terms_accepted: true,
          terms_version: TERMS_VERSION,
        });

        if (IS_BINS) {
          var dAddr = el('deliveryAddr').value.trim();
          if (!dAddr) { el('err').textContent = 'Enter a delivery address — where should we bring your bins?'; return; }
          body.fulfillment = 'delivery';
          body.delivery_address = dAddr;
          body.pickup_address = el('pickupAddr').value.trim() || null;
          if (IS_CUSTOM) body.bin_quantity = Math.max(10, parseInt(el('binQty').value, 10) || 10);
        } else {
          var ful = (document.querySelector('input[name="fulfillment"]:checked') || {}).value || 'pickup';
          body.fulfillment = ful;
          if (ful === 'delivery') {
            var addr = (el('deliveryAddr') || {}).value ? el('deliveryAddr').value.trim() : '';
            if (!addr) { el('err').textContent = 'Enter a delivery address, or choose customer pickup.'; return; }
            body.delivery_address = addr;
          }
        }

        var btn = el('continueBtn');
        btn.disabled = true; btn.textContent = 'Working…';
        try {
          var res = await fetch('/api/bookings', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          var data = await res.json().catch(function () { return {}; });
          if (!res.ok) throw new Error(data.error || 'Could not create the booking.');
          window.location.href = '/book/' + data.id + '/contract';
        } catch (err) {
          el('err').textContent = err.message;
          btn.disabled = false; btn.textContent = 'Continue to Sign →';
        }
      });
    })();
  </script>

  <% if (typeof facebookPixelId !== 'undefined' && facebookPixelId) { %>
  <!-- Meta Pixel — InitiateCheckout (customer started the booking flow) -->
  <script>
    if (window.fbq) fbq('track', 'InitiateCheckout', {
      content_name: <%- JSON.stringify(trailer.name) %>,
      content_ids: [<%- JSON.stringify(trailer.slug) %>],
      value: <%= (quote.total_cents / 100).toFixed(2) %>,
      currency: 'USD'
    });
  </script>
  <% } %>
</body>
</html>
