<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= trailer.name %> — Availability & Quote | Black Swamp Totes</title>
  <meta name="description" content="Check availability and book the <%= trailer.name %> bin package from Black Swamp Totes. Free delivery and pickup throughout Northwest Ohio." />
  <link rel="icon" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/site.css" />
  <%- typeof analyticsHead !== 'undefined' ? analyticsHead : '' %>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-head">
    <div class="site-head-inner">
      <a class="back" href="/#packages">‹ <span>Packages</span></a>
      <a href="/" aria-label="Black Swamp Totes home"><%- include("partials/cattail") %></a>
      <a class="call" href="tel:+14196737001" aria-label="Call Black Swamp Totes">Call</a>
    </div>
  </header>

  <main class="container" id="main">
    <div class="detail">
      <!-- Left: trailer info -->
      <section>
        <div class="crumb">Packages / Bins</div>
        <h1 class="display"><%= trailer.name %></h1>
        <% if (trailer.size_label) { %><div class="eyebrow" style="margin-bottom:18px;"><%= trailer.size_label %></div><% } %>

        <% if (trailer.photo_url) { %>
        <div class="detail-photo"><img src="<%= trailer.photo_url %>" alt="<%= trailer.name %>" /></div>
        <% } %>

        <% if (trailer.description) { %><p class="dim"><%= trailer.description %></p><% } %>

        <% if (Array.isArray(trailer.specs) && trailer.specs.length) { %>
        <ul class="specs">
          <% trailer.specs.forEach(function (s) { %><li><%= s %></li><% }); %>
        </ul>
        <% } %>

        <div class="eyebrow" style="margin-bottom:10px;">Rate</div>
        <div class="price-matrix">
          <div class="cell">
            <div class="amt"><%= fmt(trailer.weekly_rate) %></div>
            <div class="per"><%= trailer.is_custom ? '/ bin / week' : '/ week' %></div>
          </div>
          <div class="cell">
            <div class="amt">Free</div>
            <div class="per">delivery &amp; pickup</div>
          </div>
          <% if (!trailer.is_custom && trailer.bin_count) { %>
          <div class="cell">
            <div class="amt"><%= trailer.bin_count %></div>
            <div class="per">bins<% if (trailer.dolly_count) { %> + <%= trailer.dolly_count %> doll<%= trailer.dolly_count === 1 ? 'y' : 'ies' %><% } %></div>
          </div>
          <% } %>
        </div>

        <p class="reqs-line">
          Free delivery and pickup throughout Toledo, Bowling Green &amp; Northwest Ohio.
          <br/>Bins are sanitized before every rental. Extensions are $0.30 per bin per day.
        </p>
      </section>

      <!-- Right: booking panel -->
      <aside class="panel">
        <h2>Pick Your Dates</h2>
        <p class="dim mono" style="font-size:12px;">Choose your delivery and pickup dates for a live quote.</p>

        <div class="step" id="cal-step">Step 1 — Delivery &amp; Pickup Dates</div>
        <div id="calendar" role="group" aria-labelledby="cal-step"></div>

        <div class="step">Step 2 — Your Estimate</div>
        <div class="quote" aria-live="polite" aria-label="Rental estimate">
          <div class="qrow"><span>Delivery → Pickup</span><span id="q-dates">—</span></div>
          <div class="qrow"><span>Rental term</span><span id="q-days">—</span></div>
          <div class="qrow"><span><%= trailer.is_custom ? 'Per bin / week' : 'Weekly rate' %></span><span><%= fmt(trailer.weekly_rate) %></span></div>
          <div class="qrow"><span>Subtotal</span><span id="q-base">—</span></div>
          <div class="qrow"><span id="q-tax-label">Tax</span><span id="q-tax">—</span></div>
          <div class="qrow"><span>Delivery &amp; pickup</span><span style="color:var(--green)">Free</span></div>
          <div class="qtotal">
            <span class="lbl">Total</span>
            <span class="val" id="q-total">$0</span>
          </div>
          <p class="err" id="q-err" role="alert"></p>
          <% if (trailer.is_custom) { %>
          <p class="qnote">Estimate shown for 10 bins — you'll choose the exact number on the next step. Free delivery and pickup. A signed rental agreement is required before delivery.</p>
          <% } else { %>
          <p class="qnote">Full balance is charged at booking. Free delivery and pickup. A signed rental agreement is required before delivery.</p>
          <% } %>
        </div>

        <button class="btn btn-primary" id="reserveBtn" type="button" disabled>Reserve &amp; Pay →</button>
        <p class="qnote" id="reserveNote" hidden></p>
      </aside>
    </div>
  </main>

  <script id="trailer-data" type="application/json"><%- JSON.stringify(trailer) %></script>
  <script src="/js/quote.js"></script>
  <script src="/js/calendar.js"></script>
  <script>
    (function () {
      var T = JSON.parse(document.getElementById('trailer-data').textContent);
      var el = function (id) { return document.getElementById(id); };
      var current = null;

      function resetQuote() {
        el('q-dates').textContent = '—';
        el('q-days').textContent = '—';
        el('q-base').textContent = '—';
        el('q-tax').textContent = '—';
        el('q-tax-label').textContent = 'Tax';
        el('q-total').textContent = '$0';
        el('q-err').textContent = '';
        el('reserveBtn').disabled = true;
        el('reserveNote').hidden = true;
      }

      function renderQuote(q, range) {
        el('q-dates').textContent = range.start + ' → ' + range.end;
        var weeks = q.weeks || q.quantity;
        el('q-days').textContent = weeks + (weeks === 1 ? ' week' : ' weeks');
        el('q-base').textContent = q.base_fmt;
        el('q-tax-label').textContent = 'Tax (' + (q.tax_rate * 100).toFixed(2).replace(/\.?0+$/, '') + '%)';
        el('q-tax').textContent = q.tax_fmt;
        el('q-total').textContent = q.total_fmt;
        el('q-err').textContent = '';
        el('reserveBtn').disabled = false;
      }

      async function onRange(range) {
        current = range;
        el('reserveNote').hidden = true;
        if (!range) { resetQuote(); return; }
        try {
          var q = await GCQuote.requestQuote({
            slug: T.slug, period_type: 'week', start_at: range.start, end_at: range.end,
          });
          renderQuote(q, range);
        } catch (e) {
          el('q-err').textContent = e.message;
          el('reserveBtn').disabled = true;
        }
      }

      el('reserveBtn').addEventListener('click', function () {
        if (!current) return;
        var p = new URLSearchParams({ slug: T.slug, start: current.start, end: current.end });
        window.location.href = '/book/new?' + p.toString();
      });

      createCalendar({ container: '#calendar', slug: T.slug, months: 2, onSelect: onRange });
    })();
  </script>

  <%- include('partials/footer') %>
</body>
</html>
